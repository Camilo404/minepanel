# =============================================================================
# Minepanel Environment Configuration
# =============================================================================
# Copy this file to .env and configure your values.
#   cp .env.example .env
# Comments on the same line after '=' become part of the value, so keep
# them on their own line.
# =============================================================================


# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------

# Auth secret. Generate with: openssl rand -base64 32
JWT_SECRET=

# Absolute host path where Minepanel stores server data and its SQLite DB.
# The backend also uses this to build host volume mounts for the per-server
# compose files it generates, so it MUST be an absolute path.
#
# For Dokploy: this MUST live OUTSIDE the compose project directory.
# With AutoDeploy enabled, Dokploy runs `git clone` on every deploy and
# clears the repo directory, which would wipe any data mounted from inside
# it. Dokploy keeps the compose at /etc/dokploy/compose/<project>/, so any
# path under /opt, /var/lib, or /srv is safe.
BASE_DIR=/opt/minepanel

# Public URL of the panel. Controls backend CORS.
FRONTEND_URL=https://minepanel.camilo404.dev

# Public URL of the API, used by the frontend to make requests.
NEXT_PUBLIC_BACKEND_URL=https://api-minepanel.camilo404.dev


# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------

# Access token TTL (e.g., 20s, 15m, 1h, 2d). Default: 2d
JWT_EXPIRES_IN=2d

# Set true ONLY for HTTP/LAN access (browsers block secure cookies otherwise).
# With HTTPS, keep false.
ALLOW_INSECURE_AUTH_COOKIES=false


# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------

# Default UI language: en, es, nl, de, pl. Default: en
NEXT_PUBLIC_DEFAULT_LANGUAGE=en


# =============================================================================
# Optional features (uncomment and fill in to enable)
# =============================================================================

# --- Password recovery (SMTP) ---
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=Minepanel <no-reply@example.com>
# PASSWORD_RESET_TOKEN_EXPIRES_IN_MINUTES=60

# --- Single Sign-On (OIDC) ---
# SSO activates only when ISSUER, CLIENT_ID, CLIENT_SECRET and REDIRECT_URI
# are all set. The REDIRECT_URI must point to the BACKEND callback.
# OIDC_ISSUER=
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=
# OIDC_SCOPES=openid email profile
# OIDC_PROVIDER_NAME=SSO
# OIDC_DISABLE_PASSWORD_LOGIN=false

# --- Subpath routing (e.g. https://mydomain.com/minepanel) ---
# BASE_PATH=
# NEXT_PUBLIC_BASE_PATH=

# --- Prefix for server compose project names ---
# COMPOSE_PROJECT=


# =============================================================================
# Configuration examples
# =============================================================================

# Local:
#   FRONTEND_URL=http://localhost:3000
#   NEXT_PUBLIC_BACKEND_URL=http://localhost:8091

# Remote by IP:
#   FRONTEND_URL=http://192.168.1.100:3000
#   NEXT_PUBLIC_BACKEND_URL=http://192.168.1.100:8091

# With domain and SSL:
#   FRONTEND_URL=https://minepanel.yourdomain.com
#   NEXT_PUBLIC_BACKEND_URL=https://api.yourdomain.com

# With subpaths behind one domain:
#   FRONTEND_URL=https://mydomain.com/minepanel
#   NEXT_PUBLIC_BACKEND_URL=https://mydomain.com/api
#   BASE_PATH=/api
#   NEXT_PUBLIC_BASE_PATH=/minepanel
